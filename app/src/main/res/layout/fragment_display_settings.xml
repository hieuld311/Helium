<?xml version="1.0" encoding="utf-8"?>
<com.hieuld.helium.widget.ExpansionScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@+id/fixedLayoutNote"
            android:paddingLeft="25dp"
            android:paddingTop="15dp"
            android:paddingRight="25dp"
            android:paddingBottom="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_settings_fixed_layout_note"
            android:drawableLeft="@drawable/ic_display_locked"
            android:drawablePadding="12dp"
            android:drawableStart="@drawable/ic_display_locked"
            app:drawableTint="?android:attr/textColorPrimary"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/flow"
            android:paddingLeft="20dp"
            android:paddingTop="12dp"
            android:paddingRight="20dp"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/display_settings_flow"
                style="@style/DisplaySettingsHeader"/>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <androidx.appcompat.widget.AppCompatButton
                    android:textColor="@color/display_settings_control_color_selector"
                    android:id="@+id/flow_auto"
                    android:layout_width="82dp"
                    android:layout_height="wrap_content"
                    android:text="@string/display_settings_flow_auto"
                    android:drawableTop="@drawable/ic_flow_auto"
                    app:drawableTint="@color/display_settings_control_color_selector"
                    style="@style/FlowStyleButton"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:textColor="@color/display_settings_control_color_selector"
                    android:id="@+id/flow_paged"
                    android:layout_width="82dp"
                    android:layout_height="wrap_content"
                    android:text="@string/display_settings_flow_paged"
                    android:drawableTop="@drawable/ic_flow_paged"
                    app:drawableTint="@color/display_settings_control_color_selector"
                    style="@style/FlowStyleButton"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:textColor="@color/display_settings_control_color_selector"
                    android:id="@+id/flow_scrolled"
                    android:layout_width="82dp"
                    android:layout_height="wrap_content"
                    android:text="@string/display_settings_flow_scrolled"
                    android:drawableTop="@drawable/ic_flow_scrolled"
                    app:drawableTint="@color/display_settings_control_color_selector"
                    style="@style/FlowStyleButton"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:background="@color/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingRight="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <SeekBar
                android:id="@+id/brightness_seek"
                android:paddingLeft="32dp"
                android:paddingRight="16dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:maxHeight="1000dp"
                android:thumb="@drawable/ic_brightness"
                android:layout_weight="1"/>
            <ImageButton
                android:id="@+id/brightness_auto"
                android:background="@drawable/action_ripple"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_brightness_auto"
                android:contentDescription="@string/display_settings_brightness_auto_desc"
                app:tint="@color/display_settings_control_color_selector"/>
        </LinearLayout>
        <View
            android:background="@color/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/theme"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/display_settings_theme"
                style="@style/DisplaySettingsHeader"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/theme_list"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/text_size"
            android:paddingLeft="24dp"
            android:paddingRight="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/display_settings_font_size"
                    style="@style/DisplaySettingsHeader"/>
                <TextView
                    android:id="@+id/textSizeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/DisplaySettingsValue"/>
            </LinearLayout>
            <ImageButton
                android:id="@+id/textSizeDecrease"
                android:background="@drawable/action_ripple"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_size_dec"
                android:contentDescription="@string/display_settings_increase_dec"
                app:tint="@color/display_settings_control_color_selector"/>
            <ImageButton
                android:id="@+id/textSizeIncrease"
                android:background="@drawable/action_ripple"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_size_inc"
                android:contentDescription="@string/display_settings_increase_inc"
                app:tint="@color/display_settings_control_color_selector"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/text_align"
            android:paddingLeft="24dp"
            android:paddingRight="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/display_settings_text_align"
                    style="@style/DisplaySettingsHeader"/>
                <TextView
                    android:id="@+id/text_align_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/DisplaySettingsValue"/>
            </LinearLayout>
            <ImageButton
                android:id="@+id/text_align_start"
                android:background="@drawable/action_ripple"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_align_start"
                android:contentDescription="@string/display_settings_text_align_start"
                app:tint="@color/display_settings_control_color_selector"/>
            <ImageButton
                android:id="@+id/text_align_justify"
                android:background="@drawable/action_ripple"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_align_justify"
                android:contentDescription="@string/display_settings_text_align_justify"
                app:tint="@color/display_settings_control_color_selector"/>
        </LinearLayout>
        <Space
            android:id="@+id/end_padding"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="8dp"/>
        <ImageButton
            android:id="@+id/expand_more"
            android:background="@drawable/action_ripple_20dp"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_expand_more"
            android:contentDescription="@null"
            app:tint="?android:attr/textColorPrimary"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/more_section"
            android:paddingBottom="8dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/margin"
                android:paddingLeft="24dp"
                android:paddingRight="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/display_settings_margin"
                        style="@style/DisplaySettingsHeader"/>
                    <TextView
                        android:id="@+id/marginValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/DisplaySettingsValue"/>
                </LinearLayout>
                <ImageButton
                    android:id="@+id/marginDecrease"
                    android:background="@drawable/action_ripple"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_size_dec"
                    android:contentDescription="@string/display_settings_increase_dec"
                    app:tint="@color/display_settings_control_color_selector"/>
                <ImageButton
                    android:id="@+id/marginIncrease"
                    android:background="@drawable/action_ripple"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_size_inc"
                    android:contentDescription="@string/display_settings_increase_inc"
                    app:tint="@color/display_settings_control_color_selector"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/line_spacing"
                android:paddingLeft="24dp"
                android:paddingRight="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/display_settings_line_spacing"
                        style="@style/DisplaySettingsHeader"/>
                    <TextView
                        android:id="@+id/lineSpacingValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/DisplaySettingsValue"/>
                </LinearLayout>
                <ImageButton
                    android:id="@+id/lineSpacingDecrease"
                    android:background="@drawable/action_ripple"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_size_dec"
                    android:contentDescription="@string/display_settings_increase_dec"
                    app:tint="@color/display_settings_control_color_selector"/>
                <ImageButton
                    android:id="@+id/lineSpacingIncrease"
                    android:background="@drawable/action_ripple"
                    android:padding="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_size_inc"
                    android:contentDescription="@string/display_settings_increase_inc"
                    app:tint="@color/display_settings_control_color_selector"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/font"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <Spinner
                    android:id="@+id/font_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/display_settings_font_spinner_right_margin"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.hieuld.helium.widget.ExpansionScrollView>
