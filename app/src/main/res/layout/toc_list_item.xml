<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/drawer_item_background_selector"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground">
    <TextView
        android:textSize="14sp"
        android:textColor="@color/drawer_text_color_selector"
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"/>
    <ImageButton
        android:id="@+id/expand"
        android:background="@drawable/action_ripple_20dp"
        android:padding="16dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:src="@drawable/ic_expand_more"
        android:contentDescription="@string/contents_expand_desc"
        app:tint="?android:attr/textColorPrimary"/>
</LinearLayout>
