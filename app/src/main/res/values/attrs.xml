<?xml version="1.0" encoding="utf-8"?>
<!--
    App-specific custom attributes for Lithium EPUB Reader.
    All library attrs (AppCompat, Material) are provided by dependencies in build.gradle
    and do NOT need to be declared here.
-->
<resources>

    <!-- ────── ScrimInsetsFrameLayout ────── -->
    <attr name="insetForeground" format="reference|color" />

    <declare-styleable name="ScrimInsetsView">
        <attr name="insetForeground" />
    </declare-styleable>

    <!-- ────── DisplayCutoutFrameLayout ────── -->
    <attr name="cutoutBackground" format="reference|color" />

    <!-- ────── Reader display ────── -->
    <declare-styleable name="EPubBookView">
        <attr name="pageScrollMode" format="enum">
            <enum name="paginated" value="0" />
            <enum name="scrolling" value="1" />
        </attr>
    </declare-styleable>

    <!-- ────── Swipe / OverScrollView ────── -->
    <declare-styleable name="OverScrollView">
        <attr name="overScrollColor" format="color" />
    </declare-styleable>

    <!-- ────── SelectionToolbarView ────── -->
    <declare-styleable name="SelectionToolbarView">
        <attr name="highlightColors" format="reference" />
    </declare-styleable>

    <!-- ────── ConstrainedContainerView ────── -->
    <declare-styleable name="ConstrainedContainerView">
        <attr name="maxHeight" format="dimension" />
    </declare-styleable>

    <!-- ────── SearchBarView ────── -->
    <declare-styleable name="SearchBarView">
        <attr name="android:hint" />
    </declare-styleable>

    <!-- ────── SystemBarsFrame ────── -->
    <declare-styleable name="SystemBarsFrame">
        <attr name="systemBarsColor" format="color" />
        <attr name="doInsetTop" format="boolean" />
        <attr name="doInsetBottom" format="boolean" />
    </declare-styleable>

    <!-- ────── Theme color attrs used in app themes ────── -->
    <attr name="readerBackground" format="color" />
    <attr name="readerForeground" format="color" />

    <!-- Theme line height -->
    <attr name="themeLineHeight" format="dimension" />

</resources>
